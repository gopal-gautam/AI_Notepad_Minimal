<Window x:Class="Minimal_Notepad_AI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Minimal_Notepad_AI.ViewModels"
        Title="AI Notepad" Height="680" Width="920"
        MinHeight="400" MinWidth="600">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="BorderBrush" Value="#AAAAAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Menu bar -->
            <RowDefinition Height="Auto"/>   <!-- Instruction / toolbar -->
            <RowDefinition Height="*"/>      <!-- Editor -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ MENU BAR ═══ -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New"       Click="OnNew"    InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open…"     Click="OnOpen"   InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save"      Click="OnSave"   InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"  Click="OnSaveAs"/>
                <Separator/>
                <MenuItem Header="E_xit"      Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_AI Settings…" Click="OnOpenSettings"/>
            </MenuItem>
        </Menu>

        <!-- ═══ INSTRUCTION / TOOLBAR ROW ═══ -->
        <Border Grid.Row="1" Background="#F3F3F3"
                BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Instruction:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="1"
                         x:Name="InstructionBox"
                         Text="{Binding InstructionText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Optional instruction, e.g. 'Rewrite professionally'"
                         Padding="6,4"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <!-- Indeterminate spinner shown while generating -->
                <ProgressBar Grid.Column="2"
                             Width="20" Height="20"
                             IsIndeterminate="True"
                             Margin="0,0,8,0"
                             Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>

                <Button Grid.Column="3"
                        Content="⚡ Generate AI"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding IsIdle}"
                        Click="OnGenerate"
                        ToolTip="Send selected text to AI (Ctrl+Enter)"
                        Margin="0,0,6,0"/>

                <Button Grid.Column="4"
                        Content="✕ Cancel"
                        Style="{StaticResource ToolbarButton}"
                        Click="OnCancelGeneration"
                        Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"
                        ToolTip="Cancel current generation"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN EDITOR ═══ -->
        <TextBox Grid.Row="2"
                 x:Name="Editor"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas, Courier New"
                 FontSize="14"
                 Padding="12"
                 BorderThickness="0"
                 TextChanged="OnEditorTextChanged"
                 ToolTip="Type here. Select text, then click Generate AI."/>

        <!-- ═══ STATUS BAR ═══ -->
        <StatusBar Grid.Row="3" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatsText}" FontSize="12" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
