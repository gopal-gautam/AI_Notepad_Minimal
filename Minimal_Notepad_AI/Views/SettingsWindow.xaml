<Window x:Class="Minimal_Notepad_AI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings – AI Notepad"
        Width="480" Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Provider -->
        <Label Grid.Row="0" Grid.Column="0" Content="Provider:"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding ProviderNames}"
                  SelectedItem="{Binding SelectedProvider}"
                  Padding="4,3"/>

        <!-- Base URL -->
        <Label Grid.Row="2" Grid.Column="0" Content="Base URL:"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- API Key -->
        <Label Grid.Row="4" Grid.Column="0" Content="API Key:"/>
        <PasswordBox x:Name="ApiKeyBox"
                     Grid.Row="4" Grid.Column="1"/>

        <!-- Model -->
        <Label Grid.Row="6" Grid.Column="0" Content="Model:"/>
        <TextBox Grid.Row="6" Grid.Column="1"
                 Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Hint -->
        <TextBlock Grid.Row="8" Grid.ColumnSpan="2"
                   Text="Settings are saved to %AppData%\AI-Notepad\settings.json"
                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Height="28"
                    Click="OnSave" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="28"
                    Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
